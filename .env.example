# =============================================================================
# FINANCED — Template des variables d'environnement
# =============================================================================
# Copie ce fichier en .env.local (gitignoré) et remplis tes vraies valeurs.
# =============================================================================

# Supabase — Project URL (publique)
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxxxxxxxx.supabase.co

# Supabase — anon public key (publique, RLS protège)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-jwt-key

# Supabase — service_role secret (server-only, bypass RLS)
SUPABASE_SERVICE_KEY=your-service-role-jwt-key

# Anthropic API — V1.5 uniquement, pas requis pour le MVP
# ANTHROPIC_API_KEY=sk-ant-api03-...

# Supabase CLI (Goal 3 — schéma) — pas requis pour la foundation V1
# SUPABASE_PROJECT_REF=
# SUPABASE_DB_PASSWORD=
